# MultiAgentOS — environment variables
# Copy to .env and fill in values. .env is gitignored.

# Anthropic API key for real Claude calls.
# BILLING ISOLATION: Never export this in your shell profile (~/.zshrc, ~/.bashrc).
# The worker reads it via: tsx --env-file=.env src/index.ts
# Claude Code authenticates separately via `claude login` (subscription, not PAYG).
ANTHROPIC_API_KEY=sk-ant-api03-...

# DB path override. Default: data/mas.db (repo root).
# MAS_DB_PATH=data/test/mas-smoke.db

# Set to 'true' only to allow seeding the default dev DB (destructive reset).
# MAS_ALLOW_DESTRUCTIVE_SEED=true
