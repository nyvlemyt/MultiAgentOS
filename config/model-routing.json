{
  "$comment": "Phase 3.5 routing (ADR 0002, CLAUDE.md §11.bis). 'claude' = pooled Claude accounts (claude_accounts; empty = the single claude-login profile). Paid APIs ship OFF; domains resolve against ENABLED sources only, walking the fallback chain.",
  "claude_accounts": [],
  "paid_apis_enabled": false,
  "providers": {
    "gemini-free": {
      "id": "gemini-free",
      "kind": "gemini",
      "apiKeyEnv": "GEMINI_API_KEY",
      "model": "gemini-2.0-flash"
    },
    "openai": {
      "id": "openai",
      "kind": "openai",
      "apiKeyEnv": "OPENAI_API_KEY",
      "model": "gpt-4o",
      "paid": true
    },
    "perplexity": {
      "id": "perplexity",
      "kind": "perplexity",
      "apiKeyEnv": "PERPLEXITY_API_KEY",
      "model": "sonar",
      "paid": true
    }
  },
  "domains": {
    "search": { "primary": "perplexity", "fallback": ["gemini-free", "claude"] },
    "code-execution": { "primary": "claude", "fallback": [] },
    "code-review": { "primary": "openai", "fallback": ["claude"] },
    "planning": { "primary": "claude", "fallback": ["openai"] },
    "memory": { "primary": "gemini-free", "fallback": ["openai", "claude"] },
    "security": { "primary": "claude", "fallback": ["openai"] },
    "ux": { "primary": "openai", "fallback": ["claude"] },
    "writing": { "primary": "openai", "fallback": ["gemini-free", "claude"] },
    "research": { "primary": "perplexity", "fallback": ["gemini-free", "claude"] }
  }
}
