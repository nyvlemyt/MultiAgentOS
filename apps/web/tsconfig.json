{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@/*": ["./*"],
      "@mas/db": ["../../packages/db/src/index.ts"],
      "@mas/db/*": ["../../packages/db/src/*"],
      "@mas/core": ["../../packages/core/src/index.ts"],
      "@mas/core/*": ["../../packages/core/src/*"],
      "@mas/agents": ["../../packages/agents/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
