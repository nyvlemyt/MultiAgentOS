{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@mas/db": ["packages/db/src/index.ts"],
      "@mas/db/*": ["packages/db/src/*"],
      "@mas/core": ["packages/core/src/index.ts"],
      "@mas/core/*": ["packages/core/src/*"],
      "@mas/agents": ["packages/agents/src/index.ts"],
      "@mas/agents/*": ["packages/agents/src/*"],
      "@mas/skills": ["packages/skills/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "build"]
}
