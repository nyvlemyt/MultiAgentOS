# --- Node / TS ---
node_modules/
.pnpm-store/
.turbo/
.next/
dist/
build/
coverage/
*.tsbuildinfo

# --- Runtime data (local-first, never commit) ---
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Secrets ---
.env
.env.*
!.env.example

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Skill cache (regeneratable) ---
data/skill-cache/
data/context-packs/
data/mission-summaries/

# --- Tauri later ---
src-tauri/target/

# --- Plugin-managed skill repos (installed via Claude Code plugin marketplace) ---
# These are each their own git repo. Tracking them as gitlinks would break
# `git push` without a .gitmodules. They are not vendored here on purpose —
# users reinstall via their plugin manager. See SKILLS_REGISTRY.md.
.claude/skills/caveman/
.claude/skills/superpowers/
.claude/skills/ui-ux-pro-max/

# --- Settings claude user ---
.claude/settings.local.json

# --- AI tool mirrors (machine-local, not for this repo) ---
# Codex CLI and tools that read the AGENTS.md convention auto-mirror
# .claude/{skills,agents} into these dirs. Local-only — never commit.
.agents/
.codex/

# --- Playwright artifacts (per-run, never committed) ---
apps/web/test-results/
apps/web/playwright-report/
apps/web/blob-report/
**/.last-run.json


# docs/claude doc — ignore binaries, commit .md sources
docs/claude\ doc/*.pdf
docs/claude\ doc/*.webloc
docs/claude\ doc/.DS_Store

# docs/ressources — ignore binaries (Notion exports), distill into .md instead
docs/ressources/*.pdf
docs/ressources/.DS_Store
