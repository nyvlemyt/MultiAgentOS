# --- Node / TS ---
node_modules/
.pnpm-store/
.turbo/
.next/
dist/
build/
coverage/
*.tsbuildinfo

# --- Runtime data (local-first, never commit) ---
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Secrets ---
.env
.env.*
!.env.example

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Skill cache (regeneratable) ---
data/skill-cache/
data/context-packs/
data/mission-summaries/

# --- Tauri later ---
src-tauri/target/

# --- Plugin-managed skill repos (installed via Claude Code plugin marketplace) ---
# These are each their own git repo. Tracking them as gitlinks would break
# `git push` without a .gitmodules. They are not vendored here on purpose —
# users reinstall via their plugin manager. See SKILLS_REGISTRY.md.
.claude/skills/caveman/
.claude/skills/superpowers/
.claude/skills/ui-ux-pro-max/

# --- Settings claude user ---
.claude/settings.local.json

# --- AI tool mirrors (machine-local, not for this repo) ---
# Codex CLI and tools that read the AGENTS.md convention auto-mirror
# .claude/{skills,agents} into these dirs. Local-only — never commit.
.agents/
.codex/

# --- Playwright artifacts (per-run, never committed) ---
apps/web/test-results/
apps/web/playwright-report/
apps/web/blob-report/
**/.last-run.json


# docs/claude-doc — ignore binaries, commit .md sources
docs/claude-doc/*.pdf
docs/claude-doc/*.webloc
docs/claude-doc/.DS_Store

# docs/resources — ignore binaries (Notion exports), distill into .md instead
docs/resources/*.pdf
docs/resources/.DS_Store
# raw markitdown full-text dumps = local read-cache for cheap reads (Grep + partial Read).
# Curated, cited distillation goes to docs/knowledge/ — don't commit raw third-party content.
docs/resources/md/
.mcp.json

# Generated skill/agent library indexes (regen via `pnpm --filter @mas/skills build-library-index`).
# Not committed: their summary prose trips Sonar S7164 secret false positives, and
# they are build artifacts. See docs/intake/2026-06-16-ecc-harvest.
packages/skills/library/index.json
packages/agents/library/index.json
.qmd/
