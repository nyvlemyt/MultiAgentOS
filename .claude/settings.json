{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/token-watch.sh\"",
            "timeout": 5,
            "statusMessage": "Vérification budget tokens session"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/frontmatter-validate.sh\"",
            "timeout": 30,
            "statusMessage": "Validation frontmatter (gardien fiche)"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"Radar savoir = docs/knowledge/vibeflow/INDEX.md. AVANT de créer/modifier un skill, agent, fichier mémoire ou ADR : consulte docs/knowledge/ (CLAUDE.md §12). Cycles apprentissage = docs/learning/.\"}}'",
            "timeout": 5,
            "statusMessage": "Rappel: consulter docs/knowledge/ (CLAUDE.md §12)"
          }
        ]
      }
    ]
  }
}
